# ==============================================================================
# PULSE - Environment Variables Configuration
# ==============================================================================
# This file serves as a template for your environment variables.
# Do NOT commit your actual .env file to version control.
#
# INSTRUCTIONS FOR HUMAN-IN-THE-LOOP:
# 1. Copy this file and rename it to `.env` (for local dev) or set these in your Cloud Run environment.
#    Command: cp .env.example .env
# 2. Fill in the values for each variable below.
# 3. For Cloud Run deployment, these variables must be provided either via the 
#    Cloud Console UI, gcloud CLI (--set-env-vars), or Secret Manager.
# ==============================================================================

# ─── Gemini API Configuration ──────────────────────────────────────────────────
# Required for the multimodal extraction features (Photo and Voice capture).
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="your_api_key_here"

# ─── Application Settings ──────────────────────────────────────────────────────
# The base URL of the application. 
# Local dev: http://localhost:5173
# Cloud Run: The URL provided after deployment (e.g., https://pulse-app-xyz.run.app)
VITE_APP_URL="http://localhost:5173"

# Node environment. Use 'development' for local dev, 'production' for Cloud Run.
NODE_ENV="development"
